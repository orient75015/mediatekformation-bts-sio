{% extends "adminbase.html.twig" %}
{% block body %}
    <h2 class="text-center mt-3">Gestion des formations</h2>
    <a href="{{ path('admin.formations.ajout') }}" class="btn btn-success mb-3 ms-3">Ajouter une formation</a>
    <table class="table table-striped">
        <caption>Liste des formations</caption>
        <thead>
            <tr>
                <th class="text-left align-top" scope="col">
                    titre<br />
                    <a href="{{ path('admin.formations.sort', {champ:'title', ordre:'ASC'}) }}" class="btn btn-info btn-sm">&#8593; croissant</a>
                    <a href="{{ path('admin.formations.sort', {champ:'title', ordre:'DESC'}) }}" class="btn btn-info btn-sm">&#8595; décroissant</a>
                    <form method="POST" action="{{ path('admin.formations.findallcontain', {champ:'title'}) }}">
                        <div class="form-group mt-1">
                            <input type="text" class="form-control form-control-sm" name="recherche"
                                   value="{% if valeur|default and not table|default %}{{ valeur }}{% endif %}">
                            <input type="hidden" name="_token" value="{{ csrf_token('filtre_title') }}">
                            <button type="submit" class="btn btn-info btn-sm mt-1">filtrer</button>
                        </div>
                    </form>
                </th>
                <th class="text-left align-top" scope="col">
                    playlist<br />
                    <a href="{{ path('admin.formations.sort', {champ:'name', ordre:'ASC'}) }}" class="btn btn-info btn-sm">&#8593; croissant</a>
                    <a href="{{ path('admin.formations.sort', {champ:'name', ordre:'DESC'}) }}" class="btn btn-info btn-sm">&#8595; décroissant</a>
                    <form method="POST" action="{{ path('admin.formations.findallcontain', {champ:'name', table:'playlist'}) }}">
                        <div class="form-group mt-1">
                            <input type="text" class="form-control form-control-sm" name="recherche"
                                   value="{% if valeur|default and table|default == 'playlist' %}{{ valeur }}{% endif %}">
                            <input type="hidden" name="_token" value="{{ csrf_token('filtre_playlist') }}">
                            <button type="submit" class="btn btn-info btn-sm mt-1">filtrer</button>
                        </div>
                    </form>
                </th>
                <th class="text-left align-top" scope="col">
                    date<br />
                    <a href="{{ path('admin.formations.sort', {champ:'publishedAt', ordre:'ASC'}) }}" class="btn btn-info btn-sm">&#8593; croissant</a>
                    <a href="{{ path('admin.formations.sort', {champ:'publishedAt', ordre:'DESC'}) }}" class="btn btn-info btn-sm">&#8595; décroissant</a>
                </th>
                <th class="text-center align-top" scope="col">
                    catégories
                    <form method="POST" action="{{ path('admin.formations.findallcontain', {champ:'name', table:'categories'}) }}">
                        <select class="form-select form-select-sm mt-1" name="recherche" onchange="this.form.submit()">
                            <option value=""></option>
                            {% for categorie in categories %}
                                <option {% if valeur|default and valeur==categorie.name %}selected{% endif %}
                                    value="{{ categorie.name }}">{{ categorie.name }}</option>
                            {% endfor %}
                        </select>
                    </form>
                </th>
                <th class="text-center align-top" scope="col">actions</th>
            </tr>
        </thead>
        <tbody>
            {% for formation in formations %}
                <tr class="align-middle">
                    <td>{{ formation.title }}</td>
                    <td>{{ formation.playlist.name }}</td>
                    <td>{{ formation.publishedAt ? formation.publishedAt|date('d/m/Y') : '' }}</td>
                    <td>
                        {% for categorie in formation.categories %}
                            {{ categorie.name }}&nbsp;
                        {% endfor %}
                    </td>
                    <td class="text-center">
                        <a href="{{ path('admin.formations.edit', {id:formation.id}) }}" class="btn btn-warning btn-sm">Modifier</a>
                        <a href="{{ path('admin.formations.suppr', {id:formation.id}) }}"
                           class="btn btn-danger btn-sm"
                           onclick="return confirm('Confirmer la suppression ?')">Supprimer</a>
                    </td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
{% endblock %}