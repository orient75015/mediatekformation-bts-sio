{% extends "adminbase.html.twig" %}
{% block body %}
    <h2 class="text-center mt-3">Gestion des playlists</h2>
    <a href="{{ path('admin.playlists.ajout') }}" class="btn btn-success mb-3 ms-3">Ajouter une playlist</a>
    <table class="table table-striped">
        <caption>Liste des playlists</caption>
        <thead>
            <tr>
                <th class="text-left align-top" scope="col">
                    playlist<br />
                    <a href="{{ path('admin.playlists.sort', {champ:'name', ordre:'ASC'}) }}" class="btn btn-info btn-sm">&#8593; croissant</a>
                    <a href="{{ path('admin.playlists.sort', {champ:'name', ordre:'DESC'}) }}" class="btn btn-info btn-sm">&#8595; décroissant</a>
                    <form method="POST" action="{{ path('admin.playlists.findallcontain', {champ:'name'}) }}">
                        <div class="form-group mt-1">
                            <input type="text" class="form-control form-control-sm" name="recherche"
                                   value="{% if valeur|default and not table|default %}{{ valeur }}{% endif %}">
                            <input type="hidden" name="_token" value="{{ csrf_token('filtre_name') }}">
                            <button type="submit" class="btn btn-info btn-sm mt-1">filtrer</button>
                        </div>
                    </form>
                </th>
                <th class="text-left align-top" scope="col">
                    catégories
                    <form method="POST" action="{{ path('admin.playlists.findallcontain', {champ:'name', table:'categories'}) }}">
                        <select name="recherche" class="form-select form-select-sm mt-1" onchange="this.form.submit()">
                            <option value="">-- toutes --</option>
                            {% for categorie in categories %}
                                <option {% if valeur|default and valeur==categorie.name %}selected{% endif %}
                                    value="{{ categorie.name }}">{{ categorie.name }}</option>
                            {% endfor %}
                        </select>
                        <input type="hidden" name="_token" value="{{ csrf_token('filtre_name') }}">
                    </form>
                </th>
                <th class="text-left align-top" scope="col">
                    nb formations<br />
                    <a href="{{ path('admin.playlists.sort', {champ:'nbformations', ordre:'ASC'}) }}" class="btn btn-info btn-sm">&#8593; croissant</a>
                    <a href="{{ path('admin.playlists.sort', {champ:'nbformations', ordre:'DESC'}) }}" class="btn btn-info btn-sm">&#8595; décroissant</a>
                </th>
                <th class="text-center align-top" scope="col">actions</th>
            </tr>
        </thead>
        <tbody>
            {% for playlist in playlists %}
                <tr class="align-middle">
                    <td>{{ playlist.name }}</td>
                    <td>
                        {% set cats = playlist.categoriesplaylist %}
                        {% for c in cats %}{{ c }}&nbsp;{% endfor %}
                    </td>
                    <td class="text-center">{{ playlist.formations|length }}</td>
                    <td class="text-center">
                        <a href="{{ path('admin.playlists.edit', {id:playlist.id}) }}" class="btn btn-warning btn-sm">Modifier</a>
                        {% if playlist.formations|length == 0 %}
                            <a href="{{ path('admin.playlists.suppr', {id:playlist.id}) }}"
                               class="btn btn-danger btn-sm"
                               onclick="return confirm('Confirmer la suppression ?')">Supprimer</a>
                        {% else %}
                            <button class="btn btn-secondary btn-sm" disabled title="Impossible : cette playlist contient des formations">Supprimer</button>
                        {% endif %}
                    </td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
{% endblock %}